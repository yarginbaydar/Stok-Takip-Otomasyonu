@model ButikStok.Models.Product

@{
    ViewData["Title"] = "Ürünü Düzenle";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-9">
            <div class="card border-0 shadow-lg rounded-4 overflow-hidden">
                <div class="card-header bg-warning text-dark py-3">
                    <h5 class="mb-0 fw-bold"><i class="bi bi-pencil-square me-2"></i>Ürün Bilgilerini Güncelle</h5>
                </div>
                <div class="card-body p-4 bg-white">
                    <form asp-action="Edit" enctype="multipart/form-data">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                        <input type="hidden" asp-for="Id" />
                        <input type="hidden" asp-for="ImageUrl" />

                        <div class="row">
                            <div class="col-md-4 text-center mb-4 mb-md-0">
                                <label class="form-label fw-bold text-muted">Ürün Görseli</label>
                                <div class="border rounded-3 p-2 bg-light mb-2 position-relative">
                                    @if (!string.IsNullOrEmpty(Model.ImageUrl))
                                    {
                                        <img id="editPreview" src="@Url.Content("~/images/products/" + Model.ImageUrl)" 
                                             class="img-fluid rounded shadow-sm" style="max-height: 220px; object-fit: cover;" />
                                    }
                                    else
                                    {
                                        <img id="editPreview" src="https://placehold.co/200?text=Resim+Yok" 
                                             class="img-fluid rounded opacity-50" />
                                    }
                                </div>
                                
                                <label class="btn btn-outline-warning btn-sm w-100 cursor-pointer">
                                    <i class="bi bi-camera-fill me-1"></i> Fotoğrafı Değiştir
                                    <input type="file" name="imageFile" class="d-none" accept="image/*" onchange="previewEditImage(this)" />
                                </label>
                                <small class="text-muted d-block mt-1" style="font-size: 0.75rem;">Değişmeyecekse boş bırakın.</small>
                            </div>

                            <div class="col-md-8">
                                <div class="form-floating mb-3">
                                    <input asp-for="Name" class="form-control" placeholder="Ürün Adı" />
                                    <label asp-for="Name">Ürün Adı</label>
                                    <span asp-validation-for="Name" class="text-danger small"></span>
                                </div>

                                <div class="form-floating mb-3">
                                    <input asp-for="Barcode" class="form-control font-monospace" placeholder="Barkod" />
                                    <label asp-for="Barcode">Barkod No</label>
                                </div>

                                <div class="row g-2 mb-3">
                                    <div class="col-6">
                                        <div class="form-floating">
                                            <input asp-for="Price" class="form-control" type="number" step="0.01" />
                                            <label asp-for="Price">Fiyat (₺)</label>
                                        </div>
                                    </div>
                                    <div class="col-6">
                                        <div class="form-floating">
                                            <input asp-for="StockQuantity" class="form-control" type="number" />
                                            <label asp-for="StockQuantity">Stok</label>
                                        </div>
                                    </div>
                                </div>

                                <div class="form-floating mb-4">
                                    <select asp-for="CategoryId" class="form-select" asp-items="ViewBag.CategoryId"></select>
                                    <label asp-for="CategoryId">Kategori</label>
                                </div>

                                <div class="d-grid gap-2">
                                    <button type="submit" class="btn btn-warning fw-bold shadow-sm py-2">
                                        <i class="bi bi-save-fill me-2"></i>DEĞİŞİKLİKLERİ KAYDET
                                    </button>
                                    <a asp-action="Index" class="btn btn-light text-secondary">Vazgeç</a>
                                </div>
                            </div>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    function previewEditImage(input) {
        if (input.files && input.files[0]) {
            var reader = new FileReader();
            reader.onload = function (e) {
                document.getElementById('editPreview').src = e.target.result;
            }
            reader.readAsDataURL(input.files[0]);
        }
    }
</script>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}