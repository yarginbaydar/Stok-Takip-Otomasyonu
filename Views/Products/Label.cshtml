@model ButikStok.Models.Product

@{
    Layout = null; // Layout kullanmıyoruz, sadece etiket basılacak
}

<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <title>Etiket Yazdır - @Model.Name</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    
    <style>
        body {
            background-color: #f0f0f0;
            display: flex;
            justify-content: center;
            align-items: center;
            height: 100vh;
            flex-direction: column;
        }

        /* ETİKET TASARIMI (5cm x 3cm Oranına Yakın) */
        .etiket-karti {
            width: 320px;
            height: 180px;
            background: white;
            border: 2px solid #000;
            padding: 10px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            font-family: 'Arial', sans-serif;
            position: relative;
            box-shadow: 0 4px 8px rgba(0,0,0,0.2);
        }

        .sol-taraf {
            width: 60%;
            display: flex;
            flex-direction: column;
            justify-content: center;
        }

        .sag-taraf {
            width: 40%;
            text-align: center;
        }

        .magaza-adi {
            font-size: 10px;
            text-transform: uppercase;
            letter-spacing: 1px;
            color: #555;
            border-bottom: 1px solid #ddd;
            padding-bottom: 2px;
            margin-bottom: 5px;
        }

        .urun-adi {
            font-weight: 900;
            font-size: 16px;
            line-height: 1.2;
            margin-bottom: 5px;
            text-transform: uppercase;
            overflow: hidden;
            display: -webkit-box;
            -webkit-line-clamp: 2;
            -webkit-box-orient: vertical;
        }

        .barkod-no {
            font-family: 'Courier New', monospace;
            font-size: 12px;
            letter-spacing: 2px;
            margin-top: 5px;
        }

        .fiyat {
            font-size: 28px;
            font-weight: bold;
            color: #000;
        }

        .fiyat span {
            font-size: 14px;
            vertical-align: top;
        }

        /* SADECE YAZDIRIRKEN GEÇERLİ OLAN AYARLAR */
        @@media print {
            body { 
                background: white; 
                height: auto; 
                display: block; 
            }
            .no-print { display: none !important; }
            .etiket-karti {
                box-shadow: none;
                border: 1px solid #000;
                page-break-inside: avoid;
                margin: 0;
                /* Sayfanın tam ortasına veya sol üstüne basması için */
            }
        }
    </style>
</head>
<body>

    <div class="no-print mb-4 text-center">
        <div class="alert alert-info">
            <i class="bi bi-printer-fill"></i> Yazdırmak için butona basın veya <strong>CTRL + P</strong> yapın.
        </div>
        <button onclick="window.print()" class="btn btn-primary btn-lg shadow">
            <i class="bi bi-printer"></i> ETİKETİ YAZDIR
        </button>
        <button onclick="window.close()" class="btn btn-secondary btn-lg shadow ms-2">
            Kapat
        </button>
    </div>

    <div class="etiket-karti">
        <div class="sol-taraf">
            <div class="magaza-adi">BUTİK STOK MAĞAZASI</div>
            <div class="urun-adi">@Model.Name</div>
            <div class="barkod-no">@Model.Barcode</div>
            <div class="fiyat">
                @Model.Price.ToString("N0")<span>₺</span>
            </div>
        </div>
        <div class="sag-taraf">
            @if (ViewBag.QrCode != null)
            {
                <img src="data:image/png;base64,@ViewBag.QrCode" style="width: 100%; height: auto;" />
            }
            <div style="font-size: 8px; margin-top: 2px;">TARAT & GÖR</div>
        </div>
    </div>

</body>
</html>