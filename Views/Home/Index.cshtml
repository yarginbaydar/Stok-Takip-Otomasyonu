@model IEnumerable<ButikStok.Models.Transaction>

@{
    ViewData["Title"] = "Genel Bakış";
}

<div class="row mb-4 g-3">
    
    <div class="col-md-3">
        <a asp-controller="Products" asp-action="Index" class="text-decoration-none">
            <div class="card text-white bg-primary shadow-sm border-0 h-100">
                <div class="card-body d-flex justify-content-between align-items-center">
                    <div>
                        <h6 class="card-title mb-0 opacity-75">Toplam Ürün</h6>
                        <h2 class="display-6 fw-bold my-1">@ViewBag.ToplamUrun</h2>
                    </div>
                    <i class="bi bi-box-seam display-4 opacity-25"></i>
                </div>
            </div>
        </a>
    </div>

    <div class="col-md-3">
        <a asp-controller="Customers" asp-action="Index" class="text-decoration-none">
            <div class="card text-white bg-success shadow-sm border-0 h-100" style="background: linear-gradient(135deg, #11998e, #38ef7d);">
                <div class="card-body d-flex justify-content-between align-items-center">
                    <div>
                        <h6 class="card-title mb-0 opacity-75">Kayıtlı Müşteri</h6>
                        <h2 class="display-6 fw-bold my-1">@ViewBag.MusteriSayisi</h2>
                    </div>
                    <i class="bi bi-people-fill display-4 opacity-25"></i>
                </div>
            </div>
        </a>
    </div>

    <div class="col-md-3">
        <div class="card text-dark bg-warning bg-opacity-75 shadow-sm border-0 h-100">
            <div class="card-body d-flex justify-content-between align-items-center">
                <div>
                    <h6 class="card-title mb-0 fw-bold">Kritik Stok</h6>
                    <h2 class="display-6 fw-bold my-1">@ViewBag.KritikStok</h2>
                </div>
                <i class="bi bi-exclamation-triangle-fill display-4 opacity-25"></i>
            </div>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card text-white bg-secondary shadow-sm border-0 h-100">
            <div class="card-body d-flex justify-content-between align-items-center">
                <div>
                    <h6 class="card-title mb-0 opacity-75">Stok Değeri</h6>
                    <h2 class="display-6 fw-bold my-1">@(((decimal?)ViewBag.ToplamMaliyet ?? 0).ToString("C0"))</h2>
                </div>
                <i class="bi bi-wallet2 display-4 opacity-25"></i>
            </div>
        </div>
    </div>
</div>

<div class="row mb-4">
    <div class="col-md-6">
        <div class="card shadow-sm border-0 h-100">
            <div class="card-header bg-white fw-bold py-3">
                <i class="bi bi-pie-chart-fill text-primary me-2"></i>Kategori Dağılımı
            </div>
            <div class="card-body">
                <canvas id="stokGrafigi" style="max-height: 250px;"></canvas>
            </div>
        </div>
    </div>
    
    <div class="col-md-6">
        <div class="card shadow-sm border-0 h-100">
             <div class="card-header bg-white fw-bold py-3">
                <i class="bi bi-trophy-fill text-warning me-2"></i>En Zengin Kategori
            </div>
            <div class="card-body d-flex flex-column justify-content-center align-items-center text-center">
                
                @{
                    string[] isimler = ViewBag.GrafikIsimler as string[] ?? new string[0];
                    int[] sayilar = ViewBag.GrafikSayilar as int[] ?? new int[0];
                    
                    string liderIsim = "Veri Yok";
                    int liderSayi = 0;

                    if (isimler.Length > 0 && sayilar.Length > 0)
                    {
                        var maxDeger = sayilar.Max(); 
                        var maxIndex = Array.IndexOf(sayilar, maxDeger);
                        
                        if (maxIndex >= 0 && maxIndex < isimler.Length)
                        {
                            liderIsim = isimler[maxIndex];
                            liderSayi = maxDeger;
                        }
                    }
                }

                @if(liderSayi > 0)
                {
                    <div class="p-4 rounded-circle bg-warning bg-opacity-10 mb-3">
                        <i class="bi bi-trophy text-warning display-1"></i>
                    </div>
                    <h4 class="text-muted small text-uppercase">Lider Kategori</h4>
                    <h2 class="fw-bold text-dark display-6">@liderIsim</h2>
                    <span class="badge bg-warning text-dark mt-2 fs-6 px-3 py-2 rounded-pill">@liderSayi Çeşit Ürün</span>
                }
                else
                {
                      <i class="bi bi-inbox text-muted display-1 mb-3"></i>
                      <h4 class="text-muted">Henüz Veri Yok</h4>
                }
            </div>
        </div>
    </div>
</div>

<div class="card shadow-sm border-0 mb-4">
    <div class="card-header bg-light fw-bold py-3">
        <div class="d-flex justify-content-between align-items-center">
            <span><i class="bi bi-clock-history me-2"></i>Son Hareketler</span>
            <small class="text-muted fw-normal">Son 10 İşlem</small>
        </div>
    </div>
    <div class="table-responsive">
        <table class="table table-hover mb-0 align-middle">
            <thead class="bg-light text-secondary small">
                <tr>
                    <th class="ps-4">TARİH</th>
                    <th>MÜŞTERİ</th> <th>ÜRÜN</th>
                    <th>İŞLEM</th>
                    <th class="text-center">ADET</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model ?? Enumerable.Empty<ButikStok.Models.Transaction>())
                {
                    <tr>
                        <td class="ps-4 text-muted small">
                            @item.Date.ToString("dd.MM.yyyy") <br>
                            <span class="text-dark fw-bold">@item.Date.ToString("HH:mm")</span>
                        </td>
                        <td>
                            @if(item.Customer != null) {
                                <a asp-controller="Customers" asp-action="Details" asp-route-id="@item.CustomerId" class="text-decoration-none fw-bold text-dark">
                                    <i class="bi bi-person-fill text-primary me-1"></i>@item.Customer.Name
                                </a>
                            } else {
                                <span class="badge bg-light text-secondary border">Peşin / Anonim</span>
                            }
                        </td>
                        <td class="fw-bold text-primary">@(item.Product?.Name ?? "Silinmiş Ürün")</td>
                        <td>
                            @if (item.Type == "Satis")
                            {
                                <span class="badge bg-danger bg-opacity-10 text-danger px-2 py-1">SATIŞ</span>
                            }
                            else
                            {
                                <span class="badge bg-success bg-opacity-10 text-success px-2 py-1">GİRİŞ</span>
                            }
                        </td>
                        <td class="text-center fw-bold fs-5">@item.Quantity</td>
                    </tr>
                }
                @if (Model == null || !Model.Any())
                {
                    <tr>
                        <td colspan="5" class="text-center text-muted py-4">
                            <i class="bi bi-emoji-neutral fs-1 d-block mb-2"></i>
                            Henüz işlem yapılmadı.
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<script>
    var etiketler = @Html.Raw(Json.Serialize(ViewBag.GrafikIsimler ?? new string[0]));
    var veriler = @Html.Raw(Json.Serialize(ViewBag.GrafikSayilar ?? new int[0]));

    if (etiketler && veriler && etiketler.length > 0) {
        const ctx = document.getElementById('stokGrafigi');
        if (ctx) {
            new Chart(ctx, {
                type: 'doughnut',
                data: {
                    labels: etiketler,
                    datasets: [{
                        label: 'Ürün Sayısı',
                        data: veriler,
                        backgroundColor: [
                            '#0d6efd', '#198754', '#ffc107', '#dc3545', '#6610f2', 
                            '#0dcaf0', '#fd7e14', '#20c997', '#d63384', '#6f42c1'
                        ],
                        borderWidth: 0,
                        hoverOffset: 10
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: {
                            position: 'right',
                            labels: {
                                boxWidth: 15,
                                font: { size: 11 }
                            }
                        }
                    },
                    layout: {
                        padding: 10
                    }
                }
            });
        }
    }
</script>