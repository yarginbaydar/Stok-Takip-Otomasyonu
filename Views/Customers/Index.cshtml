@model IEnumerable<ButikStok.Models.Customer>
@using Microsoft.Extensions.Configuration
@inject IConfiguration Configuration

@{
    ViewData["Title"] = "Müşteri Portföyü";
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold text-dark mb-0"><i class="bi bi-people-fill text-primary"></i> Müşteri Portföyü</h2>
            <p class="text-muted small mb-0">Toplam @Model.Count() kayıtlı müşteri.</p>
        </div>
        <a asp-action="Create" class="btn btn-primary rounded-pill px-4 shadow-sm">
            <i class="bi bi-person-plus-fill me-2"></i>Yeni Müşteri
        </a>
    </div>

    <div class="card border-0 shadow rounded-4 overflow-hidden">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-light text-secondary small">
                    <tr>
                        <th class="ps-4 py-3 text-uppercase">Müşteri</th>
                        <th class="text-uppercase">İletişim</th>
                        <th class="text-uppercase">Alışveriş Hacmi</th>
                        <th class="text-end pe-4 text-uppercase">İşlemler</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        var infoModalId = "infoModal_" + item.Id;
                        var deleteModalId = "deleteModal_" + item.Id;
                        
                        // --- DİNAMİK WHATSAPP MANTIĞI ---
                        string whatsappLink = "#";
                        bool hasPhone = !string.IsNullOrEmpty(item.PhoneNumber);
                        
                        if (hasPhone)
                        {
                            var rawPhone = item.PhoneNumber ?? ""; 
                            var phone = rawPhone.Replace(" ", "").Replace("-", "").Replace("(", "").Replace(")", "");
                            if (phone.StartsWith("0")) phone = "9" + phone;
                            else if (!phone.StartsWith("90")) phone = "90" + phone;
                            
                            // PROFESYONEL DOKUNUŞ: İsmi 'appsettings.json' dosyasından çekiyoruz!
                            // Eğer dosyada bulamazsa yedek olarak "Bizim Butik" yazar.
                            string dukkanIsmi = Configuration["ButikAyarlari:DukkanAdi"] ?? "Bizim Butik"; 
                            
                            var mesaj = Uri.EscapeDataString($"Merhaba {item.Name}, {dukkanIsmi}'ten yazıyorum...");
                            whatsappLink = $"https://wa.me/{phone}?text={mesaj}";
                        }

                        <tr>
                            <td class="ps-4">
                                <span class="fw-bold text-dark">@item.Name</span>
                            </td>
                            <td>
                                <small class="text-muted">@(item.PhoneNumber ?? "-")</small>
                            </td>
                            <td>
                                @if (item.DebtBalance > 0)
                                {
                                    <span class="badge bg-primary bg-opacity-10 text-primary rounded-pill px-3 py-2 fw-bold border border-primary border-opacity-25">
                                        <i class="bi bi-bag-check-fill me-1"></i> @item.DebtBalance.ToString("C2") Toplam Alışveriş
                                    </span>
                                }
                                else
                                {
                                    <span class="badge bg-light text-secondary rounded-pill px-3 py-2 border">
                                        Henüz Alışveriş Yok
                                    </span>
                                }
                            </td>
                            <td class="text-end pe-4">
                                <div class="btn-group shadow-sm rounded-pill overflow-hidden border">
                                    
                                    @if (hasPhone)
                                    {
                                        <a href="@whatsappLink" target="_blank" class="btn btn-sm btn-success text-white border-end" title="WhatsApp Mesajı">
                                            <i class="bi bi-whatsapp"></i>
                                        </a>
                                    }
                                    else
                                    {
                                        <button class="btn btn-sm btn-light text-muted border-end" disabled>
                                            <i class="bi bi-whatsapp"></i>
                                        </button>
                                    }

                                    <button type="button" class="btn btn-sm btn-info text-white border-end" 
                                            data-bs-toggle="modal" data-bs-target="#@infoModalId" title="Kişisel Bilgiler">
                                        <i class="bi bi-info-circle-fill"></i>
                                    </button>

                                    <a asp-action="Details" asp-controller="Customers" asp-route-id="@item.Id" 
                                       class="btn btn-sm btn-warning text-dark border-end" title="Alışveriş Geçmişi">
                                        <i class="bi bi-clock-history"></i>
                                    </a>
                                    
                                    <button type="button" class="btn btn-sm btn-light" 
                                            data-bs-toggle="modal" data-bs-target="#@deleteModalId" title="Sil">
                                        <i class="bi bi-trash3-fill text-danger"></i>
                                    </button>
                                </div>
                            </td>
                        </tr>

                        <div class="modal fade" id="@infoModalId" tabindex="-1" aria-hidden="true">
                            <div class="modal-dialog modal-dialog-centered">
                                <div class="modal-content border-0 shadow-lg rounded-4">
                                    <div class="modal-header bg-info text-white border-0 py-3">
                                        <h5 class="modal-title fw-bold"><i class="bi bi-person-vcard me-2"></i>Müşteri Profil Kartı</h5>
                                        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                                    </div>
                                    <div class="modal-body p-4 text-center">
                                        <div class="bg-info bg-opacity-10 text-info rounded-circle d-flex align-items-center justify-content-center mx-auto mb-3" style="width: 70px; height: 70px;">
                                            <i class="bi bi-person-heart fs-1"></i>
                                        </div>
                                        <h4 class="fw-bold mb-1">@item.Name</h4>
                                        <p class="text-muted mb-4 small"><i class="bi bi-envelope-at me-1"></i> @(string.IsNullOrEmpty(item.Email) ? "E-Posta yok" : item.Email)</p>
                                        <div class="p-4 bg-primary bg-opacity-10 border-start border-primary border-5 rounded-3 text-start">
                                            <h6 class="fw-bold text-primary mb-2 small text-uppercase">Fiziksel Bilgiler</h6>
                                            <p class="mb-0 text-dark fs-5 fw-medium" style="white-space: pre-line;">
                                                @(string.IsNullOrEmpty(item.Notes) ? "Bilgi girilmemiş." : item.Notes)
                                            </p>
                                        </div>
                                    </div>
                                    <div class="modal-footer border-0">
                                        <button type="button" class="btn btn-light rounded-pill px-4 w-100" data-bs-dismiss="modal">Kapat</button>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="modal fade" id="@deleteModalId" tabindex="-1" aria-hidden="true">
                            <div class="modal-dialog modal-dialog-centered modal-sm">
                                <div class="modal-content border-0 shadow-lg rounded-4">
                                    <div class="modal-body p-4 text-center">
                                        <i class="bi bi-exclamation-octagon-fill text-danger display-3 mb-3"></i>
                                        <h5 class="fw-bold text-dark">Emin misin?</h5>
                                        <p class="text-muted small"><strong>@item.Name</strong> silinecek. Tüm geçmiş temizlenecek.</p>
                                        <form asp-action="Delete" asp-route-id="@item.Id" method="post">
                                            <div class="d-grid gap-2 mt-4">
                                                <button type="submit" class="btn btn-danger rounded-pill fw-bold">EVET, SİL</button>
                                                <button type="button" class="btn btn-light rounded-pill text-muted" data-bs-dismiss="modal">VAZGEÇ</button>
                                            </div>
                                        </form>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                </tbody>
            </table>
            @if (!Model.Any()) { <div class="text-center py-5 text-muted">Kayıt yok.</div> }
        </div>
    </div>
</div>

<style>
    .table-hover tbody tr:hover { background-color: rgba(13, 110, 253, 0.03); transition: 0.2s; }
    .btn-group .btn { padding: 0.5rem 1rem; }
    .modal-content { animation: fadeInScale 0.2s ease-out; }
    @@keyframes fadeInScale {
        from { opacity: 0; transform: scale(0.95); }
        to { opacity: 1; transform: scale(1); }
    }
</style>