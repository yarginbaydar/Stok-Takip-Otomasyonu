@model IEnumerable<ButikStok.Models.Transaction>

@{
    ViewData["Title"] = "Raporlar";

    // --- BASİT HESAPLAMALAR ---
    // Not: Gerçek muhasebe için geçmiş fiyatı işlem anında kaydetmek gerekir.
    // Şimdilik ürünün güncel fiyatı üzerinden tahmini ciro hesaplıyoruz.
    var satislar = Model.Where(x => x.Type == "Satis");
    var girisler = Model.Where(x => x.Type == "Giris");

    decimal tahminiCiro = satislar.Sum(x => (x.Product?.Price ?? 0) * x.Quantity);
    int toplamSatilanAdet = satislar.Sum(x => x.Quantity);
    int toplamGirenStok = girisler.Sum(x => x.Quantity);
}

<div class="container py-4">

    <div class="row g-3 mb-4">
        <div class="col-md-4">
            <div class="card border-0 shadow-sm overflow-hidden text-white" style="background: linear-gradient(135deg, #11998e, #38ef7d);">
                <div class="card-body p-4 position-relative">
                    <h6 class="text-uppercase mb-1 opacity-75 fw-bold">Toplam Tahmini Ciro</h6>
                    <h2 class="display-6 fw-bold mb-0">@tahminiCiro.ToString("C2")</h2>
                    <i class="bi bi-wallet2 position-absolute top-50 end-0 translate-middle-y me-3 display-1 opacity-25"></i>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card border-0 shadow-sm overflow-hidden text-white" style="background: linear-gradient(135deg, #3a7bd5, #3a6073);">
                <div class="card-body p-4 position-relative">
                    <h6 class="text-uppercase mb-1 opacity-75 fw-bold">Satılan Ürün</h6>
                    <h2 class="display-6 fw-bold mb-0">@toplamSatilanAdet <span class="fs-6 fw-normal">Adet</span></h2>
                    <i class="bi bi-bag-check position-absolute top-50 end-0 translate-middle-y me-3 display-1 opacity-25"></i>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card border-0 shadow-sm overflow-hidden text-white" style="background: linear-gradient(135deg, #FF8008, #FFC837);">
                <div class="card-body p-4 position-relative">
                    <h6 class="text-uppercase mb-1 opacity-75 fw-bold">Depoya Giren</h6>
                    <h2 class="display-6 fw-bold mb-0">@toplamGirenStok <span class="fs-6 fw-normal">Adet</span></h2>
                    <i class="bi bi-box-seam position-absolute top-50 end-0 translate-middle-y me-3 display-1 opacity-25"></i>
                </div>
            </div>
        </div>
    </div>

    <div class="card shadow border-0 rounded-4 overflow-hidden">
        <div class="card-header bg-white py-3 d-flex justify-content-between align-items-center">
            <div>
                <h5 class="mb-0 fw-bold text-dark"><i class="bi bi-clock-history text-primary me-2"></i>Son İşlem Hareketleri</h5>
                <p class="text-muted small mb-0">Dükkanda gerçekleşen tüm alış ve satışlar.</p>
            </div>
            <a asp-action="Index" class="btn btn-light btn-sm rounded-pill px-3 border"><i class="bi bi-arrow-clockwise"></i> Yenile</a>
        </div>
        
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-light text-secondary small">
                    <tr>
                        <th class="ps-4 py-3">TARİH / SAAT</th>
                        <th>ÜRÜN BİLGİSİ</th>
                        <th>İŞLEM TÜRÜ</th>
                        <th class="text-center">ADET</th>
                        <th class="text-end pe-4">TUTAR ETKİSİ</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        // Satır rengini belirle (Satışsa şeffaf yeşil, girişse şeffaf mavi)
                        string rowClass = item.Type == "Satis" ? "bg-success bg-opacity-10" : "";
                        
                        <tr>
                            <td class="ps-4">
                                <div class="d-flex flex-column">
                                    <span class="fw-bold text-dark">@item.Date.ToString("dd.MM.yyyy")</span>
                                    <span class="text-muted small">@item.Date.ToString("HH:mm")</span>
                                </div>
                            </td>
                            <td>
                                @if (item.Product != null)
                                {
                                    <div class="d-flex align-items-center">
                                        @if(!string.IsNullOrEmpty(item.Product.ImageUrl))
                                        {
                                            <img src="~/images/products/@item.Product.ImageUrl" class="rounded border me-3 shadow-sm" style="width: 40px; height: 40px; object-fit: cover;">
                                        }
                                        else
                                        {
                                            <div class="bg-light rounded border me-3 d-flex align-items-center justify-content-center" style="width: 40px; height: 40px;">
                                                <i class="bi bi-image text-muted"></i>
                                            </div>
                                        }
                                        <div>
                                            <span class="fw-bold text-dark d-block">@item.Product.Name</span>
                                            <small class="text-muted">Barkod: @(item.Product.Barcode ?? "-")</small>
                                        </div>
                                    </div>
                                }
                                else
                                {
                                    <span class="text-danger fst-italic"><i class="bi bi-trash"></i> Silinmiş Ürün</span>
                                }
                            </td>
                            <td>
                                @if (item.Type == "Satis")
                                {
                                    <span class="badge rounded-pill bg-success px-3 py-2">
                                        <i class="bi bi-shop"></i> SATIŞ
                                    </span>
                                }
                                else
                                {
                                    <span class="badge rounded-pill bg-warning text-dark px-3 py-2">
                                        <i class="bi bi-box-arrow-in-down"></i> STOK GİRİŞİ
                                    </span>
                                }
                            </td>
                            <td class="text-center">
                                <span class="fw-bold fs-5">@item.Quantity</span>
                            </td>
                            <td class="text-end pe-4">
                                @if (item.Product != null)
                                {
                                    decimal toplamTutar = (item.Product.Price * item.Quantity);
                                    
                                    @if(item.Type == "Satis")
                                    {
                                        <span class="text-success fw-bold">+ @toplamTutar.ToString("C2")</span>
                                    }
                                    else
                                    {
                                        <span class="text-muted small">Stok Değeri: @toplamTutar.ToString("C2")</span>
                                    }
                                }
                                else
                                {
                                    <span>-</span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        @if (!Model.Any())
        {
            <div class="text-center py-5">
                <div class="bg-light rounded-circle d-inline-block p-4 mb-3">
                    <i class="bi bi-clipboard-data text-muted display-4"></i>
                </div>
                <h5 class="text-muted">Henüz işlem kaydı bulunmuyor.</h5>
                <p class="text-muted small">Satış yaptıkça veya stok ekledikçe burası dolacak.</p>
                <a asp-controller="Products" asp-action="Index" class="btn btn-primary">Ürünlere Git</a>
            </div>
        }
    </div>
</div>