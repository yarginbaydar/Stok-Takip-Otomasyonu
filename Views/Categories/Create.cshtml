@model ButikStok.Models.Category

@{
    ViewData["Title"] = "Yeni Kategori Ekle";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card border-0 shadow-lg rounded-4">
                <div class="card-header bg-white border-bottom-0 pt-4 pb-0 text-center">
                    <div class="bg-success bg-opacity-10 p-3 d-inline-block rounded-circle text-success mb-2">
                        <i class="bi bi-folder-plus display-6"></i>
                    </div>
                    <h3 class="fw-bold text-dark">Yeni Kategori</h3>
                    <p class="text-muted small">Dükkana yeni bir reyon ekliyorsun.</p>
                </div>
                
                <div class="card-body p-4">
                    <form asp-action="Create">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                        
                        <div class="form-floating mb-4">
                            <input asp-for="Name" class="form-control" placeholder="Örn: Pantolon" />
                            <label asp-for="Name" class="text-secondary">Kategori Adı (Örn: Kazak)</label>
                            <span asp-validation-for="Name" class="text-danger small"></span>
                        </div>

                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-success btn-lg shadow-sm">
                                <i class="bi bi-check-lg"></i> Kaydet ve Oluştur
                            </button>
                            <a asp-action="Index" class="btn btn-light text-secondary">
                                <i class="bi bi-arrow-left"></i> Listeye Dön
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}