<!DOCTYPE html>
<html lang="tr" class="h-100">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Yargın Stok Takip Sistemi</title>
    <meta name="description" content="Yargın Baydar tarafından geliştirilen, ASP.NET Core tabanlı, hızlı ve güvenli Butik Stok Takip ve Müşteri Yönetim Sistemi.">
    
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

    <style>
        /* 1. Sayfa yüksekliğini ayarla */
        html, body {
            height: 100%;
        }

        body {
            background-color: #f8f9fa;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            /* Flex yapısı: Bu sayede footer'ı iteleyeceğiz */
            display: flex;
            flex-direction: column;
        }

        /* 2. HEADER TASARIMI */
        .navbar {
            background: linear-gradient(to right, #1e3c72, #2a5298); /* Lacivert Geçişli */
            box-shadow: 0 4px 6px -1px rgba(0,0,0,0.1);
        }
        .navbar-brand { font-weight: 800; letter-spacing: 1px; color: #fff !important; }
        .nav-link { color: rgba(255,255,255,0.9) !important; font-weight: 500; transition: all 0.3s; margin-right: 5px; }
        .nav-link:hover { color: #ffd700 !important; transform: translateY(-1px); }
        .nav-link i { margin-right: 4px; }

        /* 3. ORTA KISIM (Sihirli Kod: flex: 1) */
        /* Bu kod, içerik az olsa bile boşluğu doldurur ve footer'ı en aşağı iter */
        main {
            flex: 1 0 auto;
        }

        /* 4. FOOTER TASARIMI */
        footer {
            flex-shrink: 0; /* Asla büzüşme */
            background-color: #1e293b; /* Koyu Tema */
            color: #94a3b8; /* Gri Yazı */
            border-top: 1px solid #334155;
            padding: 15px 0;
            font-size: 13px;
            margin-top: auto; /* Kendini en dibe it */
        }
        
        .user-badge {
            background-color: rgba(255,255,255,0.15);
            padding: 5px 12px;
            border-radius: 20px;
            color: #fff;
            font-size: 0.85rem;
        }
    </style>
</head>

<body>
    
    <header>
        <nav class="navbar navbar-expand-sm navbar-dark mb-4">
            <div class="container-fluid px-4">
                <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">
                    <i class="bi bi-shop-window"></i> Butik<span style="color:#ffd700">Panel</span>
                </a>
                
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item"><a class="nav-link" asp-controller="Home" asp-action="Index"><i class="bi bi-speedometer2"></i> Özet</a></li>
                        <li class="nav-item"><a class="nav-link" asp-controller="Products" asp-action="Index"><i class="bi bi-tag-fill"></i> Ürünler</a></li>
                        <li class="nav-item"><a class="nav-link" asp-controller="Categories" asp-action="Index"><i class="bi bi-list-ul"></i> Kategoriler</a></li>
                        <li class="nav-item"><a class="nav-link" asp-controller="Transactions" asp-action="Index"><i class="bi bi-bar-chart-line-fill"></i> Raporlar</a></li>
                        <li class="nav-item"><a class="nav-link" asp-controller="Users" asp-action="Index"><i class="bi bi-people-fill"></i> Personel</a></li>
                    </ul>

                    <div class="d-flex align-items-center mt-2 mt-sm-0">
                        @if (User.Identity != null && User.Identity.IsAuthenticated)
                        {
                            <div class="user-badge me-3">
                                <i class="bi bi-person-circle"></i> @User.Identity.Name
                            </div>
                            <a asp-controller="Account" asp-action="Logout" class="btn btn-sm btn-danger text-white shadow-sm">
                                <i class="bi bi-power"></i> Çıkış
                            </a>
                        }
                    </div>
                </div>
            </div>
        </nav>
    </header>

    <main role="main">
        <div class="container pb-4">
            @RenderBody()
        </div>
    </main>

  <footer class="border-top footer text-muted">
    <div class="container text-center">
        &copy; 2026 - <strong>Yargın Baydar</strong> - <a href="https://linkedin.com/in/yargın-baydar-342246295">Benimle İletişime Geç</a>
    </div>
</footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>